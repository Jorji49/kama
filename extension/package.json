{
  "name": "kama-ai-prompt-optimizer",
  "displayName": "Kama - AI Prompt Optimizer",
  "description": "Transform rough ideas into perfect AI prompts. 100% local, no API keys needed. Your data stays private.",
  "version": "3.0.3",
  "publisher": "AhmetKayraKama",
  "icon": "media/kama-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jorji49/kama"
  },
  "homepage": "https://github.com/Jorji49/kama#readme",
  "bugs": {
    "url": "https://github.com/Jorji49/kama/issues"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.96.0"
  },
  "galleryBanner": {
    "color": "#000000",
    "theme": "dark"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "ai",
    "prompt",
    "prompt-engineering",
    "local-ai",
    "llm",
    "claude",
    "gpt",
    "gemini",
    "copilot",
    "privacy"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kama-sidebar",
          "title": "Kama",
          "icon": "media/kama-icon.svg"
        }
      ]
    },
    "views": {
      "kama-sidebar": [
        {
          "type": "webview",
          "id": "kama.vibePanel",
          "name": "Kama"
        }
      ]
    },
    "commands": [
      {
        "command": "kama.sendVibe",
        "title": "Kama: Send Vibe"
      },
      {
        "command": "kama.startBrain",
        "title": "Kama: Start Brain"
      },
      {
        "command": "kama.sendToAgent",
        "title": "Kama: Send to Agent"
      },
      {
        "command": "kama.generateFromSelection",
        "title": "Kama: Generate Prompt from Selection"
      }
    ],
    "keybindings": [
      {
        "command": "kama.generateFromSelection",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Kama",
      "properties": {
        "kama.brainServerUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8420",
          "description": "URL of the Kama Brain server. Change only if running Brain on a different machine or port.",
          "order": 1
        },
        "kama.model": {
          "type": "string",
          "default": "llama3.2-1b",
          "description": "Local GGUF model for prompt generation. Models auto-download on first use. Options: llama3.2-1b (fast), llama3.2-3b (recommended), phi3.5-mini, gemma2-2b.",
          "order": 2
        },
        "kama.maxContextFiles": {
          "type": "number",
          "default": 30,
          "description": "Maximum number of project files to scan for context. Higher values give more context but slower generation. Recommended: 20-50.",
          "minimum": 5,
          "maximum": 100,
          "order": 3
        },
        "kama.autoSendToAgent": {
          "type": "boolean",
          "default": false,
          "description": "Automatically send the generated prompt to the AI agent after generation.",
          "order": 4
        },
        "kama.temperature": {
          "type": "number",
          "default": 0.1,
          "description": "Temperature for prompt generation (0.0-1.0). Lower = more focused. Recommended: 0.1 for coding prompts.",
          "minimum": 0,
          "maximum": 1,
          "order": 5
        },
        "kama.maxTokens": {
          "type": "number",
          "default": 2048,
          "description": "Maximum tokens for generated prompts. Recommended: 1024-2048 for most tasks, 3072+ for complex architecture prompts.",
          "minimum": 512,
          "maximum": 8192,
          "order": 6
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.7.0"
  }
}